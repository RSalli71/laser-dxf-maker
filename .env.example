# Beispiel-Umgebungsvariablen
# Kopiere diese Datei nach ".env" und trage deine Werte ein.
# IMPORTANT: Niemals Secrets in Git committen.

APP_ENV=development
LOG_LEVEL=info

# --- Next.js ---
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_NAME="My App"

# --- Optional: Auth ---
# AUTH_SECRET=please-change-me
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=please-change-me

# --- Optional: Database / Prisma ---
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/dbname"

# --- Optional: APIs ---
# OPENWEATHER_API_KEY=your_key_here
